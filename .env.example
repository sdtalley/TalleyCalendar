# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
#
# These are APP-LEVEL credentials only. Per-user OAuth tokens and Apple
# passwords are stored in Redis, managed via the Settings UI.

# ── Google Calendar (one OAuth app for all family members) ───────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft Outlook (one Azure app registration for all family members) ────
# Create at: portal.azure.com → Entra ID → App Registrations
# Use "Accounts in any organizational directory AND personal Microsoft accounts"
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# ── Upstash Redis (stores per-user tokens, family config, app settings) ─────
# Create free DB at: upstash.com → REST API tab → copy URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Login (simple family password) ───────────────────────────────────────────
AUTH_USERNAME=
AUTH_PASSWORD=

# ── Google Drive (screensaver photos — simple API key, NOT OAuth) ────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → API key
# Enable "Google Drive API" in the same project as Google Calendar.
GOOGLE_API_KEY=
